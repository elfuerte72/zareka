{
  "$schema": "https://opencode.ai/config.json",
  "model": "yandex/gpt://{FOLDER_ID}/yandexgpt/latest",
  "instructions": ["~/.config/opencode/zareka.ru.md"],
  "provider": {
    "yandex": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Yandex AI Studio",
      "options": {
        "baseURL": "https://llm.api.cloud.yandex.net/v1",
        "apiKey": "{env:YANDEX_API_KEY}",
        "headers": {
          "x-folder-id": "{FOLDER_ID}",
          "x-data-logging-enabled": "false"
        }
      },
      "models": {
        "gpt://{FOLDER_ID}/yandexgpt/latest": {
          "name": "YandexGPT 5.1 Pro (Яндекс)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "gpt://{FOLDER_ID}/yandexgpt-lite/latest": {
          "name": "YandexGPT 5 Lite (Яндекс)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
